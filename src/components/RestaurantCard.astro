---
interface Props {
  id: string;
  name: string;
  category: string[];
  cuisine: string;
  priceRange: number;
  rating: number;
  reviewCount: number;
  address: string;
  googleMapsUrl: string;
  landmark: string;
  walkingMinutes: number;
  tags: string[];
  hours: string;
  image: string | null;
  dishes: string[];
}

const { id, name, category, cuisine, priceRange, rating, reviewCount, address, googleMapsUrl, landmark, walkingMinutes, tags, hours, image, dishes } = Astro.props;

const cuisineLabels: Record<string, string> = {
  taiwanese: '台式',
  japanese: '日式',
  korean: '韓式',
  chinese: '中式',
  western: '西式',
  southeast_asian: '東南亞',
  hotpot: '火鍋',
  beverage: '飲料',
  other: '其他',
};

const categoryLabels: Record<string, string> = {
  breakfast: '早餐',
  lunch: '午餐',
  dinner: '晚餐',
  snacks: '小吃',
};

const priceLabel = '$'.repeat(priceRange);
const cuisineLabel = cuisineLabels[cuisine] || cuisine;

const cuisineEmojis: Record<string, string> = {
  taiwanese: '🍚', japanese: '🍣', korean: '🥘', chinese: '🥟',
  western: '🍔', southeast_asian: '🍜', hotpot: '🫕', beverage: '🧋', other: '🍽️',
};
const emoji = cuisineEmojis[cuisine] || '🍽️';
---

<div
  class="card"
  data-id={id}
  data-categories={category.join(',')}
  data-cuisine={cuisine}
  data-price={priceRange}
  data-rating={rating}
  data-walking={walkingMinutes}
  data-landmark={landmark}
  data-review-count={reviewCount}
>
  <!-- 餐廳圖片 -->
  <div class="card-image">
    {image ? (
      <img src={image} alt={name} loading="lazy" />
    ) : (
      <div class="card-image-placeholder">
        <span class="card-image-emoji">{emoji}</span>
      </div>
    )}
  </div>

  <div class="card-body">
    <div class="card-header">
      <div>
        <div class="card-name">{name}</div>
        <div class="card-meta">
          <span class="card-rating">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="12" height="12"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {rating}
          </span>
          <span>({reviewCount})</span>
          <span class="card-price">{priceLabel}</span>
          <span class="card-walking">🚶 {walkingMinutes}分</span>
        </div>
      </div>
      <button class="card-fav-btn" data-fav-id={id} title="收藏" aria-label="收藏">&#9825;</button>
    </div>

    <div class="card-tags">
      <span class="card-cuisine-tag">{cuisineLabel}</span>
      {category.map(c => <span class="card-tag">{categoryLabels[c] || c}</span>)}
    </div>

    {dishes.length > 0 && (
      <div class="card-dishes">
        <span class="card-dishes-label">招牌：</span>
        {dishes.join(' / ')}
      </div>
    )}

    <div class="card-address">{address} | {hours}</div>

    <div class="card-actions">
      <a class="card-action-btn primary" href={googleMapsUrl} target="_blank" rel="noopener">Google Maps</a>
      <button class="card-action-btn secondary card-expand-btn" data-expand-id={id}>紀錄</button>
    </div>

    <div class="card-personal" id={`personal-${id}`}>
      <div class="personal-row">
        <span class="personal-label">造訪次數</span>
        <div class="visit-counter">
          <span class="visit-count" data-visit-id={id}>0 次</span>
          <button class="visit-add-btn" data-visit-add={id}>+1</button>
        </div>
      </div>
      <div class="personal-row">
        <span class="personal-label">私心評價</span>
        <div class="my-rating-stars" data-myrating-id={id}>
          <button data-star="1">&#9733;</button>
          <button data-star="2">&#9733;</button>
          <button data-star="3">&#9733;</button>
          <button data-star="4">&#9733;</button>
          <button data-star="5">&#9733;</button>
        </div>
      </div>
      <div class="personal-row" style="flex-direction:column;align-items:stretch;gap:4px;">
        <span class="personal-label">備註</span>
        <textarea class="personal-note" data-note-id={id} rows="2" placeholder="例：必點雞腿飯"></textarea>
      </div>
      <div class="personal-row">
        <span class="personal-label" style="color:var(--color-danger)">不再去</span>
        <div class="blacklist-toggle">
          <input type="checkbox" data-blacklist-id={id} />
        </div>
      </div>
    </div>
  </div>
</div>
