---
import '../styles/global.css';

interface Props {
  title?: string;
  activePage?: 'browse' | 'random' | 'map' | 'favorites';
}

const { title = '八德美食探索', activePage = 'browse' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="桃園八德美食探索 - 快速找到附近好吃的餐廳" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
</head>
<body>
  <script is:inline>
    // === Favorites & Personal Data Helpers (Global) ===
    window.BadeFood = {
      FAVORITES_KEY: 'bade-food-favorites',
      PERSONAL_KEY: 'bade-food-personal',

      getFavorites() {
        try { return JSON.parse(localStorage.getItem(this.FAVORITES_KEY)) || []; }
        catch { return []; }
      },

      isFavorite(id) {
        return this.getFavorites().includes(id);
      },

      toggleFavorite(id) {
        const favs = this.getFavorites();
        const idx = favs.indexOf(id);
        if (idx >= 0) favs.splice(idx, 1);
        else favs.push(id);
        localStorage.setItem(this.FAVORITES_KEY, JSON.stringify(favs));
        return idx < 0; // returns true if added
      },

      getPersonalData() {
        try { return JSON.parse(localStorage.getItem(this.PERSONAL_KEY)) || {}; }
        catch { return {}; }
      },

      getPersonal(id) {
        const data = this.getPersonalData();
        return data[id] || { visitCount: 0, myRating: 0, note: '', blacklisted: false };
      },

      setPersonal(id, fields) {
        const data = this.getPersonalData();
        data[id] = { ...this.getPersonal(id), ...fields };
        localStorage.setItem(this.PERSONAL_KEY, JSON.stringify(data));
        return data[id];
      },

      incrementVisit(id) {
        const p = this.getPersonal(id);
        return this.setPersonal(id, { visitCount: p.visitCount + 1 });
      },

      isBlacklisted(id) {
        return this.getPersonal(id).blacklisted;
      },

      // === Custom Restaurants (user-added via Google Places) ===
      CUSTOM_KEY: 'bade-food-custom',

      getCustomRestaurants() {
        try { return JSON.parse(localStorage.getItem(this.CUSTOM_KEY)) || []; }
        catch { return []; }
      },

      addCustomRestaurant(restaurant) {
        var customs = this.getCustomRestaurants();
        if (customs.some(function(r) { return r.id === restaurant.id; })) return false;
        customs.push(restaurant);
        localStorage.setItem(this.CUSTOM_KEY, JSON.stringify(customs));
        return true;
      },

      removeCustomRestaurant(id) {
        var customs = this.getCustomRestaurants().filter(function(r) { return r.id !== id; });
        localStorage.setItem(this.CUSTOM_KEY, JSON.stringify(customs));
        var favs = this.getFavorites().filter(function(f) { return f !== id; });
        localStorage.setItem(this.FAVORITES_KEY, JSON.stringify(favs));
        var personal = this.getPersonalData();
        delete personal[id];
        localStorage.setItem(this.PERSONAL_KEY, JSON.stringify(personal));
      },

      isCustom(id) {
        return id && id.indexOf('custom-') === 0;
      },

      // === 營業時間判斷 ===
      isOpenNow(openingHours) {
        if (!openingHours || !openingHours.length) return null; // 無資料
        var now = new Date();
        var day = now.getDay(); // 0=Sun
        var hhmm = ('0' + now.getHours()).slice(-2) + ('0' + now.getMinutes()).slice(-2);

        for (var i = 0; i < openingHours.length; i++) {
          var p = openingHours[i];
          if (p.day !== day) continue;
          // 跨日營業（close < open 表示過午夜）
          if (p.close < p.open) {
            if (hhmm >= p.open || hhmm < p.close) return true;
          } else {
            if (hhmm >= p.open && hhmm < p.close) return true;
          }
        }

        // 也檢查前一天的跨日營業
        var yesterday = (day + 6) % 7;
        for (var j = 0; j < openingHours.length; j++) {
          var q = openingHours[j];
          if (q.day !== yesterday) continue;
          if (q.close < q.open && hhmm < q.close) return true;
        }

        return false;
      },

      openStatusHtml(openingHours) {
        var status = this.isOpenNow(openingHours);
        if (status === null) return '<span class="open-status unknown">⚪ 未知</span>';
        if (status) return '<span class="open-status open">🟢 營業中</span>';
        return '<span class="open-status closed">🔴 休息中</span>';
      }
    };
  </script>

  <slot />

  <nav class="bottom-nav" aria-label="主選單">
    <a href={`${base}`} class:list={[{ active: activePage === 'browse' }]}>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <span>探索</span>
    </a>
    <a href={`${base}map/`} class:list={[{ active: activePage === 'map' }]}>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      <span>地圖</span>
    </a>
    <a href={`${base}random/`} class:list={[{ active: activePage === 'random' }]}>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="8" cy="8" r="1.5" fill="currentColor"/><circle cx="16" cy="8" r="1.5" fill="currentColor"/><circle cx="8" cy="16" r="1.5" fill="currentColor"/><circle cx="16" cy="16" r="1.5" fill="currentColor"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/></svg>
      <span>隨機</span>
    </a>
    <a href={`${base}favorites/`} class:list={[{ active: activePage === 'favorites' }]}>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      <span>收藏</span>
    </a>
  </nav>

</body>
</html>
