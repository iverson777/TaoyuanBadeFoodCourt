---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/restaurants.json';
---

<BaseLayout title="美食地圖 | 八德美食" activePage="map">
  <div class="page-header">
    <h1>美食地圖</h1>
    <p>點擊標記查看餐廳資訊</p>
  </div>

  <div class="map-container" id="map-container">
    <div id="map" style="width:100%;height:100%;"></div>
    <div id="map-error" style="display:none;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:#fff;padding:20px;border-radius:12px;box-shadow:0 2px 12px rgba(0,0,0,0.15);max-width:90%;text-align:center;z-index:10;">
      <div style="font-size:24px;margin-bottom:8px;">😢</div>
      <div style="font-weight:700;margin-bottom:6px;">地圖載入失敗</div>
      <div id="map-error-msg" style="font-size:12px;color:#888;word-break:break-all;"></div>
    </div>
  </div>

  <script type="application/json" id="map-data" set:html={JSON.stringify(data.restaurants.map(r => ({
    id: r.id,
    name: r.name,
    lat: r.lat,
    lng: r.lng,
    rating: r.rating,
    reviewCount: r.reviewCount,
    priceRange: r.priceRange,
    cuisine: r.cuisine,
    address: r.address,
    hours: r.hours,
    dishes: r.dishes,
    googleMapsUrl: r.googleMapsUrl,
    category: r.category,
  })))} />

  <script is:inline>
    var cuisineLabelsMap = {
      taiwanese: '台式', japanese: '日式', korean: '韓式', chinese: '中式',
      western: '西式', southeast_asian: '東南亞', hotpot: '火鍋', beverage: '飲料', other: '其他'
    };

    // Catch Google Maps API errors
    window.gm_authFailure = function() {
      var el = document.getElementById('map-error');
      var msg = document.getElementById('map-error-msg');
      el.style.display = 'block';
      msg.textContent = 'API 金鑰驗證失敗 (gm_authFailure)。請檢查 Google Cloud Console 的 API 金鑰設定。';
    };

    function initMap() {
      try {
      var restaurants = JSON.parse(document.getElementById('map-data').textContent);
      // Merge custom restaurants from localStorage
      var customs = window.BadeFood.getCustomRestaurants();
      customs.forEach(function(r) {
        if (r.lat && r.lng && !restaurants.some(function(s) { return s.id === r.id; })) {
          restaurants.push(r);
        }
      });
      var center = { lat: 24.9510, lng: 121.2850 };

      var map = new google.maps.Map(document.getElementById('map'), {
        zoom: 15,
        center: center,
        disableDefaultUI: true,
        zoomControl: true,
        gestureHandling: 'greedy',
      });

      var infoWindow = new google.maps.InfoWindow();

      // 用 Geocoder 標出「我的位置」藍點
      var geocoder = new google.maps.Geocoder();
      geocoder.geocode({ address: '桃園市八德區永福街46號' }, function(results, status) {
        if (status === 'OK' && results[0]) {
          var homePos = results[0].geometry.location;
          new google.maps.Marker({
            position: homePos,
            map: map,
            title: '我的位置',
            icon: {
              path: google.maps.SymbolPath.CIRCLE,
              fillColor: '#4285F4',
              fillOpacity: 1,
              strokeColor: '#fff',
              strokeWeight: 3,
              scale: 9,
            },
            zIndex: 999,
          });
          // 加個淡藍色外圈
          new google.maps.Circle({
            center: homePos,
            radius: 30,
            map: map,
            fillColor: '#4285F4',
            fillOpacity: 0.15,
            strokeColor: '#4285F4',
            strokeOpacity: 0.3,
            strokeWeight: 1,
          });
          map.setCenter(homePos);
        }
      });

      var cuisineColors = {
        taiwanese: '#e8803a',
        japanese: '#e63946',
        korean: '#9b59b6',
        chinese: '#d4a017',
        western: '#2a9d8f',
        southeast_asian: '#27ae60',
        hotpot: '#c0392b',
        beverage: '#3498db',
        other: '#95a5a6',
      };

      restaurants.forEach(function(r) {
        if (!r.lat || !r.lng) return;

        var marker = new google.maps.Marker({
          position: { lat: r.lat, lng: r.lng },
          map: map,
          title: r.name,
          icon: {
            path: google.maps.SymbolPath.CIRCLE,
            fillColor: cuisineColors[r.cuisine] || '#e8803a',
            fillOpacity: 0.9,
            strokeColor: '#fff',
            strokeWeight: 2,
            scale: 10,
          },
        });

        var price = '$'.repeat(r.priceRange);
        var cLabel = cuisineLabelsMap[r.cuisine] || r.cuisine;
        var dishesText = r.dishes && r.dishes.length > 0 ? r.dishes.join(' / ') : '';

        marker.addListener('click', function() {
          infoWindow.setContent(
            '<div style="font-family:-apple-system,sans-serif;max-width:220px;line-height:1.4;">' +
              '<div style="font-weight:700;font-size:14px;margin-bottom:4px;">' + r.name + '</div>' +
              '<div style="font-size:12px;color:#666;margin-bottom:4px;">' +
                '⭐ ' + r.rating + ' (' + r.reviewCount + ') | ' + price + ' | ' + cLabel +
              '</div>' +
              (dishesText ? '<div style="font-size:11px;color:#e8803a;margin-bottom:4px;">招牌：' + dishesText + '</div>' : '') +
              '<div style="font-size:11px;color:#888;">' + r.address + '</div>' +
              '<div style="font-size:11px;color:#888;margin-bottom:6px;">' + r.hours + '</div>' +
              '<a href="' + r.googleMapsUrl + '" target="_blank" rel="noopener"' +
                ' style="display:inline-block;background:#e8803a;color:#fff;padding:4px 12px;border-radius:6px;font-size:12px;text-decoration:none;">' +
                '導航' +
              '</a>' +
            '</div>'
          );
          infoWindow.open(map, marker);
        });
      });
      } catch(e) {
        var el = document.getElementById('map-error');
        var msg = document.getElementById('map-error-msg');
        el.style.display = 'block';
        msg.textContent = e.message;
      }
    }
  </script>

  <script is:inline defer
    src="https://maps.googleapis.com/maps/api/js?key=AIzaSyAQSkrYp-4i8rwj6g_atgi1-_1Lv3ZrJOU&callback=initMap">
  </script>

  <style>
    .map-container {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 56px;
      z-index: 1;
    }
    .page-header {
      position: relative;
      z-index: 2;
      background: rgba(250, 247, 242, 0.92);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      margin: 0;
      padding: 10px 12px 6px;
    }
  </style>
</BaseLayout>
