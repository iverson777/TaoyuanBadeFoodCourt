---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/restaurants.json';

const cuisineLabels: Record<string, string> = {
  taiwanese: '台式', japanese: '日式', korean: '韓式', chinese: '中式',
  western: '西式', southeast_asian: '東南亞', hotpot: '火鍋', beverage: '飲料', other: '其他',
};
const categoryLabels: Record<string, string> = {
  breakfast: '早餐', lunch: '午餐', dinner: '晚餐', snacks: '小吃',
};
---

<BaseLayout title="隨機選餐廳 | 八德美食" activePage="random">
  <div class="page-header">
    <h1>今天吃什麼？</h1>
    <p>按按鈕或搖手機，讓命運決定！</p>
  </div>

  <div class="container">
    <!-- Quick Filters for Random -->
    <div class="filter-section">
      <h3>篩選條件（可選）</h3>
      <div class="filter-pills" data-filter-group="r-category" style="margin-bottom:6px;">
        <button class="filter-pill" data-value="breakfast">早餐</button>
        <button class="filter-pill" data-value="lunch">午餐</button>
        <button class="filter-pill" data-value="dinner">晚餐</button>
        <button class="filter-pill" data-value="snacks">小吃</button>
      </div>
      <div class="filter-pills" data-filter-group="r-cuisine" style="margin-bottom:6px;">
        <button class="filter-pill" data-value="taiwanese">台式</button>
        <button class="filter-pill" data-value="japanese">日式</button>
        <button class="filter-pill" data-value="korean">韓式</button>
        <button class="filter-pill" data-value="western">西式</button>
        <button class="filter-pill" data-value="hotpot">火鍋</button>
      </div>
      <div class="filter-section">
        <h3>步行距離</h3>
        <div class="filter-pills" data-filter-group="r-walking">
          <button class="filter-pill" data-value="5">5分鐘內</button>
          <button class="filter-pill" data-value="10">10分鐘內</button>
          <button class="filter-pill" data-value="15">15分鐘內</button>
        </div>
      </div>
      <div class="filter-section">
        <h3>Lucky 最低評分</h3>
        <div class="filter-range">
          <input type="range" id="lucky-rating" min="3.5" max="5" step="0.1" value="4.3" />
          <span id="lucky-rating-value">4.3★</span>
        </div>
      </div>
    </div>

    <div class="picker-container">
      <div class="picker-buttons">
        <button class="picker-btn random" id="random-btn">
          🎲<br/>隨機選
        </button>
        <button class="picker-btn lucky" id="lucky-btn">
          ✨<br/>Lucky!
        </button>
      </div>

      <div class="picker-result" id="picker-result">
        <div class="empty-state">
          <div class="icon">👆</div>
          <p>按上面的按鈕開始！</p>
          <p style="font-size:0.75rem;margin-top:8px;">也可以搖一搖手機</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Embed restaurant data for client-side use -->
  <script type="application/json" id="restaurant-data" set:html={JSON.stringify(data.restaurants)} />

  <script is:inline define:vars={{ cuisineLabels, categoryLabels }}>
  (function() {
    const allData = JSON.parse(document.getElementById('restaurant-data').textContent);
    const resultEl = document.getElementById('picker-result');
    const randomBtn = document.getElementById('random-btn');
    const luckyBtn = document.getElementById('lucky-btn');
    const luckySlider = document.getElementById('lucky-rating');
    const luckyValue = document.getElementById('lucky-rating-value');
    const base = document.querySelector('link[rel="icon"]')?.href?.replace('favicon.svg', '') || '/TaoyuanBadeFoodCourt/';

    // Filter state
    const rFilters = { category: null, cuisine: null, walking: null };

    // Filter pill toggles
    document.querySelectorAll('[data-filter-group^="r-"]').forEach(group => {
      const key = group.dataset.filterGroup.replace('r-', '');
      group.addEventListener('click', (e) => {
        const pill = e.target.closest('.filter-pill');
        if (!pill) return;
        const wasActive = pill.classList.contains('active');
        group.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
        if (wasActive) { pill.classList.remove('active'); rFilters[key] = null; }
        else { pill.classList.add('active'); rFilters[key] = pill.dataset.value; }
      });
    });

    luckySlider.addEventListener('input', () => {
      luckyValue.textContent = luckySlider.value + '★';
    });

    function getFiltered() {
      return allData.filter(r => {
        if (rFilters.category && !r.category.includes(rFilters.category)) return false;
        if (rFilters.cuisine && r.cuisine !== rFilters.cuisine) return false;
        if (rFilters.walking && r.walkingMinutes > parseInt(rFilters.walking)) return false;
        if (window.BadeFood.isBlacklisted(r.id)) return false;
        return true;
      });
    }

    function getLucky() {
      const minRating = parseFloat(luckySlider.value);
      return getFiltered().filter(r => r.rating >= minRating);
    }

    function pickRandom(list) {
      if (list.length === 0) return null;
      return list[Math.floor(Math.random() * list.length)];
    }

    function renderResult(restaurant, isLucky) {
      if (!restaurant) {
        resultEl.innerHTML = '<div class="empty-state"><div class="icon">😅</div><p>沒有符合條件的餐廳</p></div>';
        return;
      }

      const r = restaurant;
      const priceLabel = '$'.repeat(r.priceRange);
      const cLabel = cuisineLabels[r.cuisine] || r.cuisine;
      const catLabels = r.category.map(c => categoryLabels[c] || c);
      const personal = window.BadeFood.getPersonal(r.id);
      const isFav = window.BadeFood.isFavorite(r.id);

      resultEl.innerHTML = `
        <div class="card" style="width:100%">
          ${isLucky ? '<span class="lucky-badge" style="position:absolute;top:10px;right:10px;">Lucky!</span>' : ''}
          <div class="card-header">
            <div>
              <div class="card-name">${r.name}</div>
              <div class="card-meta">
                <span class="card-rating">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  ${r.rating}
                </span>
                <span>(${r.reviewCount})</span>
                <span class="card-price">${priceLabel}</span>
                <span class="card-walking">🚶 ${r.walkingMinutes}分</span>
              </div>
            </div>
          </div>
          <div class="card-tags">
            <span class="card-cuisine-tag">${cLabel}</span>
            ${catLabels.map(c => `<span class="card-tag">${c}</span>`).join('')}
            ${r.tags.map(t => `<span class="card-tag">${t}</span>`).join('')}
          </div>
          <div class="card-address">${r.address}</div>
          <div class="card-hours">${r.hours}</div>
          ${personal.visitCount > 0 ? `<div style="font-size:0.8rem;color:var(--color-text-light);margin-top:6px;">已造訪 ${personal.visitCount} 次${personal.myRating ? ' | 私心 ' + '★'.repeat(personal.myRating) : ''}</div>` : ''}
          <div class="card-actions">
            <a class="card-action-btn primary" href="${r.googleMapsUrl}" target="_blank" rel="noopener">Google Maps 導航</a>
          </div>
        </div>
      `;
    }

    function animatePick(list, isLucky) {
      if (list.length === 0) {
        renderResult(null, isLucky);
        return;
      }

      let count = 0;
      const totalFlips = 8 + Math.floor(Math.random() * 5);
      const final = pickRandom(list);

      resultEl.classList.add('spinning');

      const interval = setInterval(() => {
        const temp = pickRandom(list);
        renderResult(temp, isLucky);
        count++;

        if (count >= totalFlips) {
          clearInterval(interval);
          resultEl.classList.remove('spinning');
          renderResult(final, isLucky);
        }
      }, 120);
    }

    randomBtn.addEventListener('click', () => animatePick(getFiltered(), false));
    luckyBtn.addEventListener('click', () => animatePick(getLucky(), true));

    // Device shake detection
    let lastShake = 0;
    function handleMotion(e) {
      const acc = e.accelerationIncludingGravity;
      if (!acc) return;
      const force = Math.abs(acc.x) + Math.abs(acc.y) + Math.abs(acc.z);
      if (force > 35 && Date.now() - lastShake > 2000) {
        lastShake = Date.now();
        animatePick(getFiltered(), false);
      }
    }

    // Request permission for iOS
    if (typeof DeviceMotionEvent !== 'undefined' && typeof DeviceMotionEvent.requestPermission === 'function') {
      document.addEventListener('click', function enableShake() {
        DeviceMotionEvent.requestPermission().then(state => {
          if (state === 'granted') window.addEventListener('devicemotion', handleMotion);
        }).catch(() => {});
        document.removeEventListener('click', enableShake);
      }, { once: true });
    } else if (typeof DeviceMotionEvent !== 'undefined') {
      window.addEventListener('devicemotion', handleMotion);
    }
  })();
  </script>
</BaseLayout>
